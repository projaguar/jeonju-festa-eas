{
  "expo": {
    "name": "JEONJU IFF",
    "slug": "jeonju-festa",
    "version": "3.0.8",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jeonjufesta",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.jeonju.fest",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "5"
    },
    "android": {
      "package": "com.jeonju.fest",
      "versionCode": 1123,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "022a4cfb-1864-47eb-b276-c9bf525ad7cf"
      },
      "router": {}
    },
    "owner": "pndsoftware",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/022a4cfb-1864-47eb-b276-c9bf525ad7cf"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
